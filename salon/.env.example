# ── Ollama (local AI — free, no account needed) ────────────────────────────
# Install Ollama from https://ollama.com, then run: ollama pull llama3.1
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3000

# Optional: used to validate incoming webhook payloads
WEBHOOK_SECRET=your_webhook_secret_here

# ── Booking ────────────────────────────────────────────────────────────────
# Full Calendly event URL, e.g. https://calendly.com/your-name/haircut
CALENDLY_EVENT_URL=https://calendly.com/your-booking-link

# ── Twilio (escalation SMS alerts) ─────────────────────────────────────────
# Leave blank to skip SMS — escalations will be logged to logs/escalations.log instead
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The Twilio phone number that sends the alert (must be in E.164 format)
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# The owner's phone number that receives escalation alerts
OWNER_PHONE_NUMBER=+1XXXXXXXXXX
